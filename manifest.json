{
  "manifest_version": 3,
  "name": "QuoteLight",
  "version": "1.0.0",
  "description": "Highlight any quote and share it with attribution to social media. Shine a light on what's worth reading.",
  "permissions": ["activeTab", "storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/quotelight.js"],
      "css": []
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/content.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
